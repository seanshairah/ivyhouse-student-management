# ─────────────────────────────────────────────────────────────
# Ivy House Student Management System — Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` with real secrets.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ivy_house?schema=public"

# App
APP_URL="http://localhost:3000"

# Authentication (secure JWT session — equivalent to NextAuth)
# Generate a strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# Email — Resend (primary provider)
RESEND_API_KEY=""
EMAIL_FROM="Ivy House <no-reply@ivyhouse.local>"

# Email — SMTP (fallback provider)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# Bulk SMS — SMS Pop (primary provider, https://smspop.co.zw)
# Create a token in the SMS Pop dashboard under "API Tokens -> Create".
# SMSPOP_SENDER_ID must be an approved sender/brand ID on your account.
SMSPOP_API_KEY=""
SMSPOP_SENDER_ID=""
SMSPOP_BASE_URL="https://smspop.co.zw/api"

# Bulk SMS — generic adapter (optional fallback provider)
BULKSMS_API_KEY=""
BULKSMS_SENDER_ID="IvyHouse"
BULKSMS_BASE_URL="https://api.bulksms.example.com"

# Paynow payment gateway
PAYNOW_INTEGRATION_ID=""
PAYNOW_INTEGRATION_KEY=""
PAYNOW_RETURN_URL="http://localhost:3000/student/payments/return"
PAYNOW_RESULT_URL="http://localhost:3000/api/payments/paynow/result"
# development = mock payments (no real keys needed). Switch to "live" with real keys.
PAYNOW_MODE="development"
# Optional. When the Paynow integration is in TEST mode, the authemail MUST
# equal the merchant's Paynow-registered email. Set this to that email to test.
# Leave blank in production/live so each payer's own email is used.
PAYNOW_AUTH_EMAIL=""
